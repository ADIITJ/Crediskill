{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalScore": { "type": "number" },
        "gamesPlayed": { "type": "number" },
        "wins": { "type": "number" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "achievements": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email"]
    },
    "Room": {
      "title": "Room",
      "description": "A game session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "theme": { "type": "string" },
        "gameType": { "type": "string", "enum": ["quiz", "guessing", "competition"] },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "currentQuestionIndex": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "answer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "displayName": { "type": "string" },
              "score": { "type": "number" },
              "lastAnswer": { "type": "string" },
              "isReady": { "type": "boolean" },
              "streak": { "type": "number" },
              "powerups": {
                "type": "object",
                "properties": {
                  "fiftyFiftyUsed": { "type": "boolean" },
                  "doublePointsUsed": { "type": "boolean" }
                }
              }
            }
          }
        },
        "isKidFriendly": { "type": "boolean" },
        "password": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "hostId", "theme", "gameType", "status", "isKidFriendly"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Game sessions"
    }
  }
}
