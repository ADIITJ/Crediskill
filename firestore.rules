rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "atharva.a.date@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Data Validation
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['id', 'hostId', 'theme', 'gameType', 'status', 'isKidFriendly']) &&
             data.id is string &&
             data.hostId is string &&
             data.theme is string &&
             data.gameType in ['quiz', 'guessing', 'competition'] &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.isKidFriendly is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      // Host can create/update/delete
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Host update
        (resource.data.hostId == request.auth.uid && isValidRoom(request.resource.data)) ||
        // Player joining or answering (limited update)
        isValidRoom(request.resource.data)
      );
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      }
    }
  }
}
